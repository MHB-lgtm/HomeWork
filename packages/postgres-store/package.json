{
  "name": "@hg/postgres-store",
  "version": "0.0.0",
  "private": true,
  "description": "PostgreSQL and Prisma persistence adapters for homework grader",
  "main": "./dist/src/index.js",
  "module": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "build": "pnpm run prisma:generate && tsc -p tsconfig.json",
    "dev": "pnpm run prisma:generate && tsc --watch -p tsconfig.json",
    "test": "vitest run",
    "prisma:validate": "prisma validate --schema prisma/schema.prisma",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "import:file-backed": "pnpm run build && node dist/scripts/import-file-backed.js"
  },
  "dependencies": {
    "@hg/domain-workflow": "workspace:*",
    "@hg/shared-schemas": "workspace:*",
    "@prisma/client": "^6.6.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "prisma": "^6.6.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  }
}
